---
import { SITE, ROUTES } from '../config';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
};
---
<nav class="nav" aria-label="Primary">
  <div class="nav-inner">
    <a href="/" class="wordmark">{SITE.name}</a>

    <button
      type="button"
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-menu"
    >Menu</button>

    <ul id="primary-menu" class="nav-list">
      {ROUTES.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { active: isActive(href) }]}
            aria-current={isActive(href) ? 'page' : undefined}
          >{label}</a>
        </li>
      ))}
    </ul>

    <div class="nav-end">
      <ThemeToggle />
    </div>
  </div>
</nav>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('primary-menu');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    menu?.classList.toggle('open', !open);
  });
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      menu.classList.remove('open');
    });
  });
  // ESC key closes the open mobile menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      btn.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('open');
      btn.focus();
    }
  });
</script>

<style>
  .nav {
    position: relative;
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-paper);
  }
  .nav-inner {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    text-decoration: none;
  }
  .wordmark:hover {
    color: var(--color-link);
    text-decoration: none;
  }

  .nav-toggle {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    cursor: pointer;
    margin-left: auto;
    margin-right: var(--space-4);
  }
  .nav-toggle:hover { color: var(--color-link); }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: none;
  }
  .nav-list.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
    padding: var(--space-4) var(--space-5);
    gap: var(--space-3);
    z-index: 10;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--color-link);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--color-ink);
  }

  .nav-end {
    display: flex;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-inner {
      padding: var(--space-5) var(--space-8);
      gap: var(--space-6);
    }
    .nav-toggle { display: none; }
    .nav-list,
    .nav-list.open {
      display: flex;
      flex-direction: row;
      position: static;
      background: transparent;
      border: 0;
      padding: 0;
      gap: var(--space-6);
      margin-left: var(--space-5);
    }
    .nav-end {
      margin-left: auto;
    }
  }
  @media (min-width: 1280px) {
    .nav-inner { padding: var(--space-5) var(--space-9); }
  }
</style>
