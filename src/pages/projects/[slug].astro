---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Lightbox from '../../components/Lightbox.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;

const labelize = (s: string) =>
  s.split('-').map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
const statusLabel = data.status.charAt(0).toUpperCase() + data.status.slice(1);
const ogImage = data.heroImage?.src;
---
<Layout
  title={`${data.title} — Bo Rodda`}
  description={data.excerpt}
  ogType="article"
  ogImage={ogImage}
>
  <article class="case-study">
    {data.heroImage && (
      <div class="case-hero-wrap">
        <header class="case-hero">
          <Image
            src={data.heroImage}
            alt={data.heroImageAlt ?? ''}
            widths={[720, 1080, 1620, 2400]}
            sizes="(min-width: 1280px) 1088px, 100vw"
            loading="eager"
            class="case-hero-image"
          />
        </header>
      </div>
    )}

    <header class="case-title-block">
      <p class="case-eyebrow">Selected work · {data.dateDisplay}</p>
      <h1 class="case-title">{data.title}</h1>
      <p class="case-subtitle">{data.subtitle}</p>
      <dl class="case-meta-strip">
        <div>
          <dt>Years</dt>
          <dd>{data.dateDisplay}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>{statusLabel}</dd>
        </div>
        {data.partners.length > 0 && (
          <div>
            <dt>Partners</dt>
            <dd>{data.partners.join(', ')}</dd>
          </div>
        )}
        {data.themes.length > 0 && (
          <div>
            <dt>Themes</dt>
            <dd>{data.themes.map(labelize).join(', ')}</dd>
          </div>
        )}
      </dl>
    </header>

    <div class="case-body">
      <div class="rich-text">
        <Content />
      </div>
    </div>

    <Lightbox />

    {(data.credits.length > 0 || data.funding.length > 0 || data.press.length > 0) && (
      <footer class="case-credits">
        {data.credits.length > 0 && (
          <section class="credit-section">
            <h2>Credits</h2>
            <dl class="credit-list">
              {data.credits.map((c) => (
                <>
                  <dt>{c.role}</dt>
                  <dd>{c.name} <span class="credit-aff">/ {c.affiliation}</span></dd>
                </>
              ))}
            </dl>
          </section>
        )}
        {data.funding.length > 0 && (
          <section class="credit-section">
            <h2>Funding</h2>
            <ul class="plain-list">
              {data.funding.map((f) => <li>{f}</li>)}
            </ul>
          </section>
        )}
        {data.press.length > 0 && (
          <section class="credit-section credit-section-wide">
            <h2>Selected coverage</h2>
            <ul class="plain-list">
              {data.press.map((p) => (
                <li>
                  {p.url
                    ? <a href={p.url} target="_blank" rel="noopener">{p.citation}</a>
                    : p.citation}
                </li>
              ))}
            </ul>
          </section>
        )}
      </footer>
    )}
  </article>
</Layout>

<style>
  .case-study {
    padding-bottom: var(--space-9);
  }

  /* ----- Hero: bounded to the nav's content extent (wordmark → toggle) ----- */
  .case-hero-wrap {
    max-width: var(--max-page);
    margin: 0 auto var(--space-7);
    padding-inline: var(--space-5);
  }
  @media (min-width: 768px) {
    .case-hero-wrap { padding-inline: var(--space-8); }
  }
  @media (min-width: 1280px) {
    .case-hero-wrap { padding-inline: var(--space-9); }
  }

  .case-hero {
    aspect-ratio: 16 / 9;
    max-height: 80vh;
    overflow: hidden;
    background: var(--color-rule);
    border-radius: var(--radius-image);
  }
  .case-hero :global(.case-hero-image) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* ----- Title block ----- */
  .case-title-block {
    max-width: var(--max-page);
    margin: var(--space-7) auto var(--space-7);
    padding: 0 var(--space-5);
  }
  @media (min-width: 768px) {
    .case-title-block { padding: 0 var(--space-8); }
  }
  @media (min-width: 1280px) {
    .case-title-block { padding: 0 var(--space-9); }
  }

  .case-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-4);
  }
  .case-title {
    font-size: clamp(2.5rem, 4.5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .case-subtitle {
    margin-top: var(--space-3);
    font-size: var(--type-h3);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.3;
    max-width: 60ch;
  }

  /* ----- Metadata strip ----- */
  .case-meta-strip {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-rule);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 768px) {
    .case-meta-strip {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-5);
    }
  }
  .case-meta-strip dt {
    font-family: var(--font-sans);
    font-size: var(--type-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
  }
  .case-meta-strip dd {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    line-height: 1.5;
  }

  /* ----- Body ----- */
  .case-body {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-9);
  }
  @media (min-width: 768px) {
    .case-body { padding-inline: var(--space-8); }
  }
  @media (min-width: 1280px) {
    .case-body { padding-inline: var(--space-9); }
  }

  /* ----- Credits block ----- */
  .case-credits {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) 0;
    border-top: 1px solid var(--color-rule);
    display: grid;
    gap: var(--space-7);
  }
  @media (min-width: 768px) {
    .case-credits {
      grid-template-columns: 2fr 1fr;
      padding-inline: var(--space-8);
    }
    .credit-section-wide {
      grid-column: 1 / -1;
    }
  }
  @media (min-width: 1280px) {
    .case-credits { padding-inline: var(--space-9); }
  }

  .case-credits h2 {
    font-family: var(--font-sans);
    font-size: var(--type-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-4);
  }

  .credit-list {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    line-height: 1.5;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-2) var(--space-5);
    margin: 0;
  }
  .credit-list dt {
    color: var(--color-ink-muted);
    font-weight: 500;
  }
  .credit-list dd {
    color: var(--color-ink);
    margin: 0;
  }
  .credit-aff {
    color: var(--color-ink-muted);
  }

  .plain-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    line-height: 1.5;
    display: grid;
    gap: var(--space-3);
  }
  .plain-list a {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
</style>
