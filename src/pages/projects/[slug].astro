---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
---
<Layout title={`${data.title} — Bo Rodda`} description={data.excerpt}>
  <article class="page case-study">
    <header class="case-header">
      <h1 class="case-title">{data.title}</h1>
      <p class="case-subtitle">{data.subtitle}</p>
      <p class="case-meta-date">{data.dateDisplay}</p>
      {data.partners.length > 0 && (
        <p class="case-meta-partners">{data.partners.join(' · ')}</p>
      )}
    </header>

    <figure class="case-hero">
      <Image
        src={data.heroImage}
        alt={data.heroImageAlt}
        widths={[480, 720, 1080, 1620]}
        sizes="(min-width: 1080px) 1080px, 100vw"
        loading="eager"
      />
    </figure>

    <div class="rich-text prose">
      <Content />
    </div>

    {(data.credits.length > 0 || data.funding.length > 0 || data.press.length > 0) && (
      <footer class="case-credits">
        {data.credits.length > 0 && (
          <section class="credit-section">
            <h2>Credits</h2>
            <dl class="credit-list">
              {data.credits.map((c) => (
                <>
                  <dt>{c.role}</dt>
                  <dd>{c.name} <span class="credit-aff">/ {c.affiliation}</span></dd>
                </>
              ))}
            </dl>
          </section>
        )}
        {data.funding.length > 0 && (
          <section class="credit-section">
            <h2>Funding</h2>
            <ul class="plain-list">
              {data.funding.map((f) => <li>{f}</li>)}
            </ul>
          </section>
        )}
        {data.press.length > 0 && (
          <section class="credit-section credit-section-wide">
            <h2>Selected coverage</h2>
            <ul class="plain-list">
              {data.press.map((p) => (
                <li>
                  {p.url
                    ? <a href={p.url} target="_blank" rel="noopener">{p.citation}</a>
                    : p.citation}
                </li>
              ))}
            </ul>
          </section>
        )}
      </footer>
    )}
  </article>
</Layout>

<style>
  .case-study {
    padding-block: var(--space-6) var(--space-9);
  }

  .case-header {
    max-width: var(--max-prose);
    margin-bottom: var(--space-7);
  }
  .case-title {
    font-size: var(--type-h1);
    font-weight: 700;
    letter-spacing: -0.015em;
  }
  .case-subtitle {
    margin-top: var(--space-3);
    font-size: var(--type-h3);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.3;
  }
  .case-meta-date {
    margin-top: var(--space-5);
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    letter-spacing: 0.04em;
  }
  .case-meta-partners {
    margin-top: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    color: var(--color-ink-muted);
    letter-spacing: 0.02em;
    line-height: 1.5;
    max-width: var(--max-prose);
  }

  .case-hero {
    margin: 0 0 var(--space-7);
    max-width: var(--max-wide);
  }
  .case-hero img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-image);
  }

  .case-credits {
    margin-top: var(--space-9);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
    max-width: var(--max-wide);
    display: grid;
    gap: var(--space-7) var(--space-7);
  }
  @media (min-width: 768px) {
    .case-credits {
      grid-template-columns: 2fr 1fr;
    }
    .credit-section-wide {
      grid-column: 1 / -1;
    }
  }

  .case-credits h2 {
    font-family: var(--font-sans);
    font-size: var(--type-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-4);
  }

  .credit-list {
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    line-height: 1.5;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-2) var(--space-5);
    margin: 0;
  }
  .credit-list dt {
    color: var(--color-ink-muted);
    font-weight: 500;
  }
  .credit-list dd {
    color: var(--color-ink);
    margin: 0;
  }
  .credit-aff {
    color: var(--color-ink-muted);
  }

  .plain-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--type-sm);
    line-height: 1.5;
    display: grid;
    gap: var(--space-3);
  }
  .plain-list a {
    color: var(--color-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }
</style>
